# ===== AI gateway (OpenAI-compatible) =====
# Put real values in .env.local only — NEVER commit .env.local.
# Both base URL and key are required for LLM features; without them the app
# still works in rules-only mode.
AI_GATEWAY_BASE_URL=
AI_GATEWAY_API_KEY=

# Optional: per-model keys, only if your provider requires separate keys.
# Falls back to AI_GATEWAY_API_KEY when empty.
MINIMAX_API_KEY=
QWEN_API_KEY=
GEMMA_API_KEY=
GEMINI_API_KEY=

# Optional: route image QA to Gemini OpenAI-compatible API.
# Leave GEMINI_BASE_URL empty to use Google's default OpenAI-compatible endpoint.
GEMINI_BASE_URL=

# Actual model IDs as exposed by your gateway (e.g. "qwen/qwen3.5-27b").
MODEL_ID_QWEN=
MODEL_ID_MINIMAX=
MODEL_ID_GEMMA=
MODEL_ID_GEMINI=gemini-2.5-flash-lite

# Role → model family routing
MODEL_CAPTION_QA=qwen
MODEL_VERIFY=minimax
MODEL_IMAGE_QA=gemma
MODEL_REPORT=minimax

# Storage / brand guidelines
STORAGE_DIR=./storage
BRAND_GUIDELINES_DIR=./brand_guidelines
